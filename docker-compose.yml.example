version: '3.8'

services:
  plex-command-center:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: plex-command-center
    restart: unless-stopped
    ports:
      - "3001:3001"
    environment:
      # ===== REQUIRED CONFIGURATION =====
      
      # Plex Media Server
      - PLEX_URL=http://192.168.1.100:32400  # Your Plex server URL
      - PLEX_TOKEN=YOUR_PLEX_TOKEN_HERE      # Get from Plex: Play media → View XML → X-Plex-Token in URL

      # Tautulli
      - TAUTULLI_URL=http://192.168.1.100:8181  # Your Tautulli URL
      - TAUTULLI_API_KEY=YOUR_TAUTULLI_KEY      # Get from Tautulli: Settings → Web Interface → API

      # Jellyseerr
      # IMPORTANT: Do NOT include trailing slash!
      - JELLYSEERR_URL=https://jellyseerr.yourdomain.com  # Your Jellyseerr URL (NO TRAILING SLASH!)
      - JELLYSEERR_API_KEY=YOUR_JELLYSEERR_KEY            # Get from Jellyseerr: Settings → API Key

      # ===== OPTIONAL: ZABBIX INTEGRATION =====
      # Enable this to see real CPU/RAM/Disk metrics from your Windows Plex server
      # Leave blank to disable (will show "Configure Zabbix" message)
      
      - ZABBIX_URL=                     # Example: http://192.168.1.50/zabbix
      - ZABBIX_USER=                    # Usually: Admin
      - ZABBIX_PASSWORD=                # Your Zabbix password
      - ZABBIX_HOST_ID=                 # Get from Zabbix: Config → Hosts → Click host → hostid=XXXXX in URL
      
      # Optional: Display Tailscale IP in server details
      - TAILSCALE_IP=                   # Example: 100.99.196.121

      # ===== APP SETTINGS =====
      
      - PORT=3001                       # Application port (default: 3001)
      - NODE_ENV=production
      - TZ=America/New_York             # Your timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)

    volumes:
      # Optional: Persist data and logs
      - ./data:/app/data
      - ./logs:/app/logs

    networks:
      - plex-network
      
    healthcheck:
      test: ["CMD", "node", "-e", "require('http').get('http://localhost:3001/api/health',(r)=>{process.exit(r.statusCode===200?0:1)})"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s

networks:
  plex-network:
    driver: bridge
